    def change_jnt_pos(self):
        dbg_s = False
        # dbg_s = True
        call_id = self.sender().objectName()
        # print(f"{call_id} button clicked")  # DBG

        wid = self.findChild(QGroupBox, "tp_gb0_wd")
        idx = int(call_id[-1])
        jn_name = self.j_refs[idx - 1]
        jnt = find_joint(self.wk_asm, jn_name)
        obj = getObjByName(wid, f"txt_jnta{idx}")
        if obj is not None and jnt is not None:
            pass
        else:
            return

        dir = 1 if call_id[-2:-1] == 'p' else -1
        step = jnt.move_pref_step
        value = self.j_vals[idx - 1] + (dir * step)
        fcl_msg(
            (f"Cid: {call_id}, ids: {idx},"
             f" Step: {step}, dir; {dir}, val: {value}\n"))

        j_t = jnt.JointType
        # validate position
        if j_t == "Slider":
            if dbg_s:
                fcl_msg((
                    f"EnableLengthMin = {jnt.EnableLengthMin}\n"
                    f"EnableLengthMax = {jnt.EnableLengthMax}\n"
                    f"LengthMin = {jnt.LengthMin}\n"
                    f"LengthMax = {jnt.LengthMax}\n"
                ))
            if jnt.EnableLengthMax:
                if value > jnt.LengthMax.Value:
                    value = jnt.LengthMax.Value
            #
            if jnt.EnableLengthMin:
                if value < jnt.LengthMin.Value:
                    value = jnt.LengthMin.Value

        elif j_t == "Revolute":
            if dbg_s:
                fcl_msg((
                    f"EnableAngleMin = {jnt.EnableAngleMin}\n"
                    f"EnableAngleMax = {jnt.EnableAngleMax}\n"
                    f"AngleMin = {jnt.AngleMin}\n"
                    f"AngleMax = {jnt.AngleMax}\n"
                ))
            #
            if jnt.EnableAngleMax:
                fcl_msg(f"LengthMin = {jnt.LengthMin}\n")
                if value > jnt.AngleMax.Value:
                    value = jnt.AngleMax.Value
            #
            if jnt.EnableAngleMin:
                if value < jnt.AngleMin.Value:
                    value = jnt.AngleMin.Value
        else:
            return

        self.j_vals[idx - 1] = value
        obj.setText(f"{value:.03f}")
        self.setJointPos(jnt, value, dbg_s)

    def check_prefs(self, jnt):
        """Check the presence of the move preferences."""
        j_t = jnt.JointType
        if j_t == "Slider":
            if 'move_pref_step' in jnt.PropertiesList:
                pass
            else:
                jnt.addProperty(
                    'App::PropertyFloat', 'move_pref_step', 'move_pref', '')
                jnt.move_pref_step = self.step_lin
        if j_t == "Revolute":
            if 'move_pref_step' in jnt.PropertiesList:
                pass
            else:
                jnt.addProperty(
                    'App::PropertyFloat', 'move_pref_step', 'move_pref', '')
                jnt.move_pref_step = self.step_ang

    def read_joints(self):
        """Read joint."""
        wid = self.findChild(QGroupBox, "tp_gb0_wd")
        lay = self.findChild(QGridLayout, "tp_gb0_l")
        if wid is None:
            return
        else:
            # print(wid.children())  # DBG
            pass

        self.j_refs = []
        row = 1
        for j_n, jnt in enumerate(self.wk_asm.Joints):
            j_t = jnt.JointType
            j_l = jnt.Label
            fcl_msg(f"{j_n} {j_l} {j_t}\n")
            if j_t == "Slider":
                j_ts = "S"
                j_u = "mm"
            elif j_t == "Revolute":
                j_ts = "R"
                j_u = "deg"
            else:
                fcl_msg(f"Joint {j_l} type {j_t} Not supported yet!\n!")
                continue
            #
            create_link_row(self, lay, row, self.fnt, j_n + 1, jnt.Name)
            set_wid_text(wid, f"txt_jnt{j_n + 1}", j_l)
            set_wid_text(wid, f"txt_jntt{j_n + 1}", j_ts)
            set_wid_text(wid, f"txt_jntu{j_n + 1}", j_u)
            btn_p = getObjByName(self, f"btn_jnt_p{j_n + 1}")
            btn_m = getObjByName(self, f"btn_jnt_m{j_n + 1}")
            btn_p.clicked.connect(self.change_jnt_pos)
            btn_m.clicked.connect(self.change_jnt_pos)
            self.check_prefs(jnt)
            self.j_refs.append(jnt.Name)
            row += 1

        # Service buttons: (Reset joints)
        btn_jnts_res = cm_btn(self, "btn_jnts_res", "Reset Joints", self.fnt, 0)
        lay.addWidget(btn_jnts_res, row, 0, 1, 2)

        btn_jnts_res.clicked.connect(self.reset_joints)
        #
        fcl_msg(f"Joints References: {self.j_refs}\n")  # DBG

    def reset_joints(self):
        """Reset joints value to 0"""
        asm_obj = self.wk_asm
        wid = self.findChild(QGroupBox, "tp_gb0_wd")
        value = 0.0
        if asm_obj is None:
            return

        for j_n, jnt in enumerate(asm_obj.Joints):
            fl_nm = f"txt_jnta{j_n + 1}"
            jnt_o2 = jnt.Offset2
            fcl_msg(f"{j_n} {jnt.Label}\n")
            fcl_msg(f"OF2:  {jnt_o2}\n")
            if jnt.JointType in ("Revolute", "Slider"):
                jnt.Offset2 = Placement(VEC0, Rotation())
            else:
                continue
            asm_obj.recompute()
            obj = getObjByName(wid, fl_nm)
            fcl_msg(f"Field name: {fl_nm}, obj: {obj}\n")  # DBG
            obj.setText(str(value))
            self.j_vals[j_n - 1] = value

    def set_defaults(self):
        """Set defaults value in the Control group."""
        wid = self.findChild(QGroupBox, "tp_gb0_wd")
        for idx in range(1, self.j_num + 1):
            obj = getObjByName(wid, f"txt_jnta{idx}")
            if obj is not None:
                obj.setText(str(self.j_vals[idx - 1]))

    def set_labels(self):
        lay = self.findChild(QGridLayout, "tp_gb0_l")
        lbl_1_wd = cm_lbl(self, "lbl_c0", "<b>Joint</b>", self.fnt, 0)
        lay.addWidget(lbl_1_wd, 0, 0, 1, 1)

        lbl_2_wd = cm_lbl(self, "lbl_c1", "<b>Joint name</b>", self.fnt, 0)
        lay.addWidget(lbl_2_wd, 0, 1, 1, 1)

        lbl_3_wd = cm_lbl(self, "lbl_c2", "<b>Type</b>", self.fnt, 0)
        lay.addWidget(lbl_3_wd, 0, 2, 1, 1)

        lbl_4_wd = cm_lbl(self, "lbl_c3", "<b>Value</b>", self.fnt, 0)
        lay.addWidget(lbl_4_wd, 0, 3, 1, 1)

        lbl_5_wd = cm_lbl(self, "lbl_c4", "<b>Unit</b>", self.fnt, 0)
        lay.addWidget(lbl_5_wd, 0, 4, 1, 1)

        lbl_6_wd = cm_lbl(self, "lbl_c5", "<b>Decrease</b>", self.fnt, 0)
        lay.addWidget(lbl_6_wd, 0, 5, 1, 1)

        lbl_7_wd = cm_lbl(self, "lbl_c6", "<b>Increase</b>", self.fnt, 0)
        lay.addWidget(lbl_7_wd, 0, 6, 1, 1)

    def set_preferences(self):
        """Set preferences."""
        if self.wk_asm:
            if self.wk_asm is not None:
                pass
            else:
                return
        else:
            return

        for j_n, jnt in enumerate(self.wk_asm.Joints):
            fcl_msg(f"{jnt.Name} | {jnt.Label} = {jnt.move_pref_step}\n")

    def set_working_asm(self):
        """Set working asm."""
        self.wrk_asm = None
        raw_sel = Gui.Selection.getSelection("", 2, True)
        esn = len(raw_sel)
        fcl_msg(f"Raw Selection: {raw_sel}\n")  # DBG

        if esn == 0:
            msg_box(
                self, "Move", self.fnt,
                ("<b>Move Selection</b><br><br>You must select at least one "
                 "element"), "w")
            return
        elif esn == 1:
            obj = raw_sel[0]
            obj_typ = obj.TypeId
            if obj_typ == "Assembly::AssemblyObject":
                switch_document(obj.Document.Name)
                setview(obj.Document.Name, 1)
                self.wk_asm = obj
                self.txt_rbnm.setText(obj.Label)
                self.set_labels()
                self.read_joints()
                self.reset_joints()

            else:
                msg_box(
                    self, "Move", self.fnt,
                    ("<b>Move Selection</b><br><br>"
                     "You must select an Assembly element"), "w")
                return

    def setJointPos(self, jnt, value, dbg_s=False):
        """Set joint position."""
        # print(idx, value)  # DBG
        fcl_msg(f"Joint: {jnt.Label}, Offset2; {jnt.Offset2} \n")
        j_t = jnt.JointType
        if j_t == "Slider":
            jnt.Offset2 = Placement(V3(0, 0, value), Rotation())
        elif j_t == "Revolute":
            jnt.Offset2 = Placement(VEC0, Rotation(value, 0, 0))
        jnt.recompute()


