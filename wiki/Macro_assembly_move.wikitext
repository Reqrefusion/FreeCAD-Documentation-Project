    def hasGraphicsView(w):
        return bool(w.findChild(QGraphicsView))

    def sanitize_title(w):
        s = w.windowTitle()
        return s.split(':')[0].strip()

    available = App.listDocuments()

    if doc_name not in available:
        return

    fcl_msg(f"available: {available}\n")
    App.setActiveDocument(doc_name)
