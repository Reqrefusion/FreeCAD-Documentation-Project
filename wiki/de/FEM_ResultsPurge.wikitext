{{GuiCommand/de
|Name=FEM ResultsPurge
|MenuLocation=Ergebnisse → Ergebnisse löschen
|Workbenches=[[FEM_Workbench/de|FEM]]
|Shortcut={{KEY|R}} {{KEY|P}}
|SeeAlso=[[FEM_tutorial|FEM Tutorial]]
