{{GuiCommand/de
|Name=Draft Mirror
|Name/de=Draft Spiegeln
|MenuLocation=Änderung → Spiegeln<br>Bearbeiten → Spiegeln
|Workbenches=[[Draft_Workbench/de|Draft]], [[BIM_Workbench/de|BIM]]
|Shortcut={{KEY|M}} {{KEY|I}}
